{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"composite": true,
		"moduleResolution": "node",
		"types": ["node", "reflect-metadata", "vite/client"],
		"paths": {
			"@main/*": ["./src/main/*"],
			"@renderer/*": ["./src/renderer/*"],
			"@shared/*": ["./src/shared/*"],
			"@services/*": ["./src/main/services/*"],
			"@modules_contracts/*": ["./src/main/modules/contracts/*"]
		}
	},
	"include": ["src", "src/preload.d.ts", "tests"]
}
